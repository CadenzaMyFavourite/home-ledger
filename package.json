{
  "name": "home-ledger",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "build:desktop-e2e": "pnpm typecheck && vite build --mode desktop-e2e",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.json && tsc --noEmit --pretty false -p tsconfig.node.json && tsc --noEmit --pretty false -p tsconfig.desktop-e2e.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:desktop:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_desktop_e2e.ps1",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "benchmark:sqlite": "python scripts/benchmark_sqlite.py",
    "android:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify_android_prerequisites.ps1",
    "android:verify:initialized": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify_android_prerequisites.ps1 -RequireInitializedProject",
    "android:init": "pnpm tauri android init --ci",
    "android:build:aab": "pnpm tauri android build -- --aab",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@hookform/resolvers": "^5",
    "@tanstack/react-query": "^5",
    "@tanstack/react-table": "^8",
    "@tanstack/react-virtual": "^3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4",
    "date-fns-tz": "^3",
    "i18next": "^25",
    "lucide-react": "^0.525.0",
    "radix-ui": "^1.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7",
    "react-i18next": "^15",
    "react-router-dom": "^7",
    "recharts": "^3.9.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@playwright/test": "^1",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/native-utils": "2.5.0",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "@wdio/types": "^9.29.1",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-react-refresh": "^0.4",
    "jsdom": "^26",
    "prettier": "^3",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8",
    "vite": "^7.0.4",
    "vitest": "^3"
  }
}
